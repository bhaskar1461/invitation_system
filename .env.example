# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key

# Database Connection
# Leave blank to use local SQLite (sqlite:///guest_invitation.db)
# For MySQL: mysql+pymysql://username:password@hostname:3306/database_name
DATABASE_URL=

# SMTP Configuration
# Set to 'simulation' to log emails to logs/email_simulation.log instead of sending them.
SMTP_HOST=simulation
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=invitations@sreenidhi.edu.in

# WhatsApp Configuration (Unified Messaging Platform)
# Set to 'production' to send live messages via the SNIST Helpdesk API, or 'simulation' to log locally.
WHATSAPP_PROVIDER=simulation
WHATSAPP_API_URL=https://103.229.250.150/unified/v2/send
